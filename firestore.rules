rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasValidLeaderboardPayload(playerId) {
      return request.resource.data.keys().hasOnly([
        'playerId',
        'initials',
        'score',
        'level',
        'battleReached',
        'loopCount',
        'endedBy',
        'createdAt',
        'updatedAt',
      ]) &&
      request.resource.data.playerId == playerId &&
      request.resource.data.initials is string &&
      request.resource.data.initials.matches('^[A-Z]{3}$') &&
      request.resource.data.score is int &&
      request.resource.data.score >= 0 &&
      request.resource.data.level is int &&
      request.resource.data.level >= 1 &&
      request.resource.data.battleReached is int &&
      request.resource.data.battleReached >= 1 &&
      request.resource.data.loopCount is int &&
      request.resource.data.loopCount >= 0 &&
      request.resource.data.endedBy in ['defeat', 'retire', 'timeout'];
    }

    match /leaderboard/{playerId} {
      allow read: if true;
      allow create: if hasValidLeaderboardPayload(playerId) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if hasValidLeaderboardPayload(playerId) &&
        resource.data.playerId == playerId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.score >= resource.data.score;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
